  "keyFeatures": [
    "Cross-platform ML inference and training",
    "Support for ONNX models from PyTorch, TensorFlow, scikit-learn",
    "Hardware acceleration via Execution Providers (CUDA, TensorRT, DirectML, etc.)",
    "Graph optimizations and model quantization",
    "Multi-language support (Python, C/C++, C#, Java, JavaScript)",
    "On-device training capabilities",
    "Mobile and edge deployment support",
    "Model serving and production deployment"
  ],
  "publicApiSurface": [
    "InferenceSession - Main class for running inference",
    "SessionOptions - Configuration for inference sessions",
    "RunOptions - Per-run configuration options",
    "OrtValue - Tensor and sparse tensor values",
    "ExecutionProvider - Hardware acceleration backends",
    "GraphOptimizationLevel - Model optimization settings",
    "QuantizationConfig - Model quantization options",
    "TrainingSession - On-device training API",
    "ORTModule - PyTorch training integration",
    "ModelQuantizer - Quantization utilities"
  ]
